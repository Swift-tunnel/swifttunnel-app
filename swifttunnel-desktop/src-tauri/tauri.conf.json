{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SwiftTunnel",
  "version": "2.5.14",
  "identifier": "net.swifttunnel.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "removeUnusedCommands": false
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "SwiftTunnel",
        "width": 1080,
        "height": 720,
        "minWidth": 940,
        "minHeight": 620,
        "decorations": true,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "SwiftTunnel Overlay",
        "width": 340,
        "height": 132,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "overlay-stats",
        "title": "SwiftTunnel In-Game Overlay",
        "width": 600,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost https://*.swifttunnel.net https://*.roblox.com https://*.rbxcdn.com; connect-src 'self' https://*.swifttunnel.net https://*.supabase.co"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "useLocalToolsDir": true,
    "publisher": "SwiftTunnel",
    "copyright": "Copyright SwiftTunnel. All rights reserved.",
    "targets": [
      "msi"
    ],
    "windows": {
      "wix": {
        "fragmentPaths": [
          "wix/nsis-migration.wxs"
        ],
        "componentGroupRefs": [
          "NsisMigration"
        ]
      }
    },
    "resources": [
      "resources/drivers",
      "resources/tools",
      "resources/swifty.png"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/Swift-tunnel/swifttunnel-app/releases/latest/download/latest.json"
      ]
    }
  }
}
